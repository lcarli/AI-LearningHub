{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Lab 030: Azure AI Foundry Hub + Project for building AI agents"
  },
  "parameters": {
    "prefix": {
      "type": "string",
      "defaultValue": "ailab",
      "maxLength": 8,
      "metadata": { "description": "Short prefix for resource names (max 8 chars)" }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Location. Use eastus or swedencentral for best model availability." }
    },
    "userObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Your Azure AD user Object ID (optional, assigns AI Developer role to you)" }
    }
  },
  "variables": {
    "aiHubName": "[concat(parameters('prefix'), '-hub-', uniqueString(resourceGroup().id))]",
    "aiProjectName": "[concat(parameters('prefix'), '-project')]",
    "storageName": "[concat(parameters('prefix'), 'st', uniqueString(resourceGroup().id))]",
    "keyVaultName": "[concat(parameters('prefix'), '-kv-', uniqueString(resourceGroup().id))]",
    "aiDeveloperRoleId": "64702f94-c441-49e6-a78b-ef80e0188fee"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "kind": "StorageV2",
      "sku": { "name": "Standard_LRS" },
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "family": "A", "name": "standard" },
        "tenantId": "[subscription().tenantId]",
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7,
        "accessPolicies": []
      }
    },
    {
      "type": "Microsoft.MachineLearningServices/workspaces",
      "apiVersion": "2024-01-01-preview",
      "name": "[variables('aiHubName')]",
      "location": "[parameters('location')]",
      "kind": "Hub",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ],
      "properties": {
        "storageAccount": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "keyVault": "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "friendlyName": "AI Agents Learning Hub",
        "description": "Azure AI Foundry Hub for Lab 030"
      }
    },
    {
      "type": "Microsoft.MachineLearningServices/workspaces",
      "apiVersion": "2024-01-01-preview",
      "name": "[variables('aiProjectName')]",
      "location": "[parameters('location')]",
      "kind": "Project",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.MachineLearningServices/workspaces', variables('aiHubName'))]"
      ],
      "properties": {
        "hubResourceId": "[resourceId('Microsoft.MachineLearningServices/workspaces', variables('aiHubName'))]",
        "friendlyName": "Outdoor Gear Agent Project",
        "description": "AI project for building the OutdoorGear customer service agent"
      }
    }
  ],
  "outputs": {
    "hubName": {
      "type": "string",
      "value": "[variables('aiHubName')]"
    },
    "projectName": {
      "type": "string",
      "value": "[variables('aiProjectName')]"
    },
    "resourceGroup": {
      "type": "string",
      "value": "[resourceGroup().name]"
    }
  }
}
